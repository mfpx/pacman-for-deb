 COMMAND = /usr/bin/bash /home/david/pacman/build/scripts/edit-script.sh ../scripts/makepkg-template.pl.in scripts/makepkg-template 0755
 description = Generating$ makepkg-template.pl.in$ with$ a$ custom$ command

