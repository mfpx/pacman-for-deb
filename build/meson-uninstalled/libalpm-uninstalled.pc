prefix=/home/david/pacman/build
srcdir=/home/david/pacman
libdir=${prefix}/lib/x86_64-linux-gnu
includedir=${prefix}/include

Name: libalpm
Description: Arch Linux package management library
URL: http://archlinux.org/pacman/
Version: 13.0.1
Requires.private: libcrypto, libarchive >= 3.0.0, libcurl >= 7.55.0, gpgme >= 1.3.0
Libs: -L${prefix}/ -lalpm
Cflags: -I${prefix}/ -I${srcdir}/ -I${prefix}/src/common -I${srcdir}/src/common -I${prefix}/lib/libalpm -I${srcdir}/lib/libalpm
